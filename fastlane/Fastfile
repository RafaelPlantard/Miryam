# frozen_string_literal: true

default_platform(:ios)

APP_IDENTIFIER = "io.swift-yah.miryam"
WATCH_IDENTIFIER = "io.swift-yah.miryam.watchkitapp"
ALL_IDENTIFIERS = [APP_IDENTIFIER, WATCH_IDENTIFIER]
PROJECT = "Miryam.xcodeproj"
SCHEME = "Miryam"
TV_SCHEME = "MiryamTV"

platform :ios do

  # ── Helpers ──────────────────────────────────────────────────────────────────

  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY"])
    )
  end

  # ── Testing ──────────────────────────────────────────────────────────────────

  desc "Run all tests"
  lane :test do
    run_tests(
      project: PROJECT,
      scheme: SCHEME,
      devices: ["iPhone 16 Pro"],
      clean: true,
      code_coverage: true,
      output_directory: "fastlane/test_output"
    )
  end

  # ── Certificates ─────────────────────────────────────────────────────────────

  desc "Sync development certificates (read-only, regenerates if new devices found)"
  lane :match_dev do
    api_key = asc_api_key
    match(
      type: "development",
      app_identifier: APP_IDENTIFIER,
      readonly: false,
      force_for_new_devices: true,
      api_key: api_key
    )
  end

  desc "Sync adhoc certificates (read-only)"
  lane :match_adhoc do
    api_key = asc_api_key
    match(
      type: "adhoc",
      app_identifier: APP_IDENTIFIER,
      readonly: true,
      api_key: api_key
    )
  end

  desc "Sync App Store certificates (read-only)"
  lane :match_appstore do
    api_key = asc_api_key
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      readonly: true,
      api_key: api_key
    )
  end

  desc "Force-regenerate dev/adhoc/appstore profiles (use after Portal capability changes)"
  lane :resync_profiles do
    api_key = asc_api_key
    ["development", "adhoc", "appstore"].each do |cert_type|
      match(
        type: cert_type,
        app_identifier: APP_IDENTIFIER,
        readonly: false,
        force: true,
        api_key: api_key
      )
    end
  end

  desc "Register Watch App ID and generate App Store profiles"
  lane :setup_watch_signing do
    api_key = asc_api_key

    # Register Watch bundle ID via ASC API
    token = Spaceship::ConnectAPI::Token.create(**api_key)
    Spaceship::ConnectAPI.token = token
    existing = Spaceship::ConnectAPI::BundleId.find(WATCH_IDENTIFIER)
    if existing
      UI.message("Bundle ID '#{WATCH_IDENTIFIER}' already exists")
    else
      Spaceship::ConnectAPI::BundleId.create(
        name: "Miryam Watch",
        identifier: WATCH_IDENTIFIER,
        platform: "IOS"
      )
      UI.success("Created Bundle ID '#{WATCH_IDENTIFIER}'")
    end

    match(
      type: "appstore",
      app_identifier: ALL_IDENTIFIERS,
      readonly: false,
      api_key: api_key
    )
  end

  desc "First-time setup: generate all cert types in MiryamCertificates repo"
  lane :setup_match do
    api_key = asc_api_key
    ["development", "adhoc", "appstore"].each do |cert_type|
      match(
        type: cert_type,
        app_identifier: ALL_IDENTIFIERS,
        readonly: false,
        api_key: api_key
      )
      # tvOS profiles (same bundle ID, different platform)
      match(
        type: cert_type,
        app_identifier: [APP_IDENTIFIER],
        platform: "tvos",
        readonly: false,
        api_key: api_key
      )
    end
  end

  # ── Capabilities ─────────────────────────────────────────────────────────────

  desc "Create CloudKit container and assign to App ID (requires Apple ID session)"
  lane :setup_cloudkit do
    container_id = "iCloud.#{APP_IDENTIFIER}"

    # Portal API requires Apple ID session auth
    Spaceship::Portal.login(ENV["FASTLANE_USER"], ENV["FASTLANE_PASSWORD"])
    Spaceship::Portal.client.team_id = ENV["APPLE_TEAM_ID"]

    # Create or find the CloudKit container
    container = Spaceship::Portal::CloudContainer.find(container_id)
    if container
      UI.message("CloudKit container '#{container_id}' already exists")
    else
      container = Spaceship::Portal::CloudContainer.create!(
        identifier: container_id,
        name: "Miryam"
      )
      UI.success("Created CloudKit container '#{container_id}'")
    end

    # Assign container to the App ID
    app = Spaceship::Portal::App.find(APP_IDENTIFIER)
    UI.user_error!("App ID #{APP_IDENTIFIER} not found in Portal") unless app

    # Associate the container with the app (passes full container objects)
    Spaceship::Portal.client.associate_cloud_containers_with_app(app, [container])
    UI.success("Assigned '#{container_id}' to App ID '#{APP_IDENTIFIER}'")
  end

  desc "Enable required capabilities on the App ID and regenerate profiles"
  lane :enable_capabilities do
    api_key = asc_api_key
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)

    bundle_id = Spaceship::ConnectAPI::BundleId.find(APP_IDENTIFIER)
    UI.user_error!("Bundle ID #{APP_IDENTIFIER} not found") unless bundle_id

    capabilities = %w[PUSH_NOTIFICATIONS ICLOUD]

    capabilities.each do |cap_type|
      begin
        settings = nil
        if cap_type == "ICLOUD"
          settings = [{ "key" => "ICLOUD_VERSION", "options" => [{ "key" => "XCODE_6" }] }]
        end
        bundle_id.create_capability(cap_type, settings: settings)
        UI.success("Enabled #{cap_type}")
      rescue => e
        if e.message.include?("already exists")
          UI.message("#{cap_type} already enabled, skipping")
        else
          UI.important("Could not enable #{cap_type}: #{e.message}")
        end
      end
    end

    # CarPlay audio is not available via the API — enable manually at
    # https://developer.apple.com/account/resources/identifiers if needed.
    UI.message("Note: CarPlay Audio must be enabled manually in the Developer Portal if not already set.")

    # Force-regenerate profiles to include the new capabilities
    ["development", "adhoc", "appstore"].each do |cert_type|
      match(
        type: cert_type,
        app_identifier: APP_IDENTIFIER,
        readonly: false,
        force: true,
        api_key: api_key
      )
    end
  end

  # ── Build & Deploy ────────────────────────────────────────────────────────────

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]
    api_key = asc_api_key
    match(
      type: "appstore",
      app_identifier: ALL_IDENTIFIERS,
      readonly: true,
      api_key: api_key
    )
    current_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0
    )
    new_build = current_build + 1
    increment_build_number(
      build_number: new_build,
      xcodeproj: PROJECT
    )
    UI.message("MIRYAM_BUILD_NUMBER:#{new_build}")
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "fastlane/builds",
      export_options: {
        iCloudContainerEnvironment: "Production"
      }
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key: api_key
    )

    # tvOS — fetch tvOS-specific profiles (same bundle ID, tvOS platform)
    match(
      type: "appstore",
      app_identifier: [APP_IDENTIFIER],
      platform: "tvos",
      readonly: false,
      api_key: api_key
    )
    build_app(
      project: PROJECT,
      scheme: TV_SCHEME,
      destination: "generic/platform=tvOS",
      export_method: "app-store",
      output_directory: "fastlane/builds",
      output_name: "MiryamTV.ipa",
      export_options: {
        iCloudContainerEnvironment: "Production"
      }
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key: api_key
    )
  end

  desc "Build and release to App Store"
  lane :release do
    setup_ci if ENV["CI"]
    api_key = asc_api_key
    match(
      type: "appstore",
      app_identifier: ALL_IDENTIFIERS,
      readonly: true,
      api_key: api_key
    )
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      clean: true
    )
    deliver(
      submit_for_review: false,
      automatic_release: false,
      force: true,
      api_key: api_key
    )
  end

  # ── App Management ───────────────────────────────────────────────────────────

  desc "Create app in App Store Connect (run once, requires 2FA)"
  lane :create_app do
    produce(
      app_identifier: APP_IDENTIFIER,
      app_name: "Miryam",
      language: "English",
      app_version: "1.0",
      sku: "miryam-moises-challenge",
      team_id: ENV["APPLE_TEAM_ID"],
      username: ENV["FASTLANE_USER"]
    )
  end

  desc "Verify app exists in App Store Connect"
  lane :verify_app do
    api_key = asc_api_key
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    if app
      UI.success("App '#{app.name}' (#{app.bundle_id}) found in App Store Connect!")
    else
      UI.user_error!("App #{APP_IDENTIFIER} not found in App Store Connect")
    end
  end

  # TODO(ci): Automate internal tester setup once fastlane bug #29556 is fixed.
  # Creating internal beta groups via API fails because fastlane sends
  # publicLinkLimitEnabled for internal groups, which Apple's API rejects.
  # Manual setup: App Store Connect → TestFlight → Internal Testing → + → Add testers

  desc "Revoke all development certificates and re-create match from scratch"
  lane :nuke_and_recreate do
    api_key = asc_api_key
    match_nuke(
      type: "development",
      api_key: api_key,
      app_identifier: ALL_IDENTIFIERS,
      skip_confirmation: true
    )
    match_nuke(
      type: "appstore",
      api_key: api_key,
      app_identifier: ALL_IDENTIFIERS,
      skip_confirmation: true
    )
    ["development", "adhoc", "appstore"].each do |cert_type|
      match(
        type: cert_type,
        app_identifier: ALL_IDENTIFIERS,
        readonly: false,
        api_key: api_key
      )
    end
  end

  desc "Register devices from devices.txt"
  lane :sync_devices do
    api_key = asc_api_key
    register_devices(
      devices_file: "fastlane/devices.txt",
      api_key: api_key
    )
  end

  desc "Bump build number, commit, and push tag"
  lane :bump_version do |options|
    version = options[:version] || UI.input("Enter new version (e.g. 1.0.1): ")
    increment_version_number(version_number: version, xcodeproj: PROJECT)
    increment_build_number(build_number: Time.now.strftime("%Y%m%d%H%M"), xcodeproj: PROJECT)
    add_git_tag(tag: "v#{version}")
    push_to_git_remote(tags: true)
  end

end
