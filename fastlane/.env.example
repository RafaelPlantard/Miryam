# Fastlane environment variables
# Copy this file to fastlane/.env and fill in your values.
# NEVER commit .env — it is gitignored.

# Apple Developer
APPLE_ID=your-apple-id@example.com
APPLE_TEAM_ID=YOUR_TEAM_ID
# App Store Connect team ID (numeric) — find via: bundle exec fastlane create_app
ITC_TEAM_ID=YOUR_ITC_TEAM_ID

# Apple ID session auth (needed for produce/create_app)
FASTLANE_USER=your-apple-id@example.com
FASTLANE_PASSWORD=your-apple-id-password
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=your-apple-application-specific-password

# App Store Connect API Key
# Generate at: https://appstoreconnect.apple.com/access/integrations/api
APP_STORE_CONNECT_API_KEY_ID=YOUR_KEY_ID
APP_STORE_CONNECT_API_ISSUER_ID=YOUR_ISSUER_ID
# Base64-encoded .p8 file: base64 -i AuthKey_XXXX.p8
APP_STORE_CONNECT_API_KEY=BASE64_ENCODED_P8_CONTENT

# Fastlane Match (code signing)
MATCH_PASSWORD=YOUR_MATCH_ENCRYPTION_PASSWORD
MATCH_GIT_URL=git@github.com:your-org/YourCertificatesRepo.git
